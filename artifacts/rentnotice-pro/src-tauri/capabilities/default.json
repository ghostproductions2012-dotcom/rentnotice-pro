{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for RentNotice Pro windows (main and aux-* secondary windows): core defaults, window title updates, native dialogs, and filesystem access scoped to the app data directories.",
  "windows": ["main", "aux-*"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "dialog:default",
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appconfig-read-recursive",
    "fs:allow-appconfig-write-recursive",
    "fs:allow-applocaldata-read-recursive",
    "fs:allow-applocaldata-write-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" },
        { "path": "$APPCONFIG" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPLOCALDATA" },
        { "path": "$APPLOCALDATA/**" }
      ]
    }
  ]
}
