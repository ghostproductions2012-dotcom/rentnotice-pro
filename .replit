modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0", "github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
EMAIL_FROM = "RentNotice Pro <noreply@rentnoticepro.com>"

[userenv.development]
ADMIN_PANEL_EMAIL = "admin@rentnoticepro.com"
ADMIN_PANEL_PASSWORD = "rnp-dev-admin-2026"
