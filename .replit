modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-rentnotice-pro"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-layout-www"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "merge-field-picker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "state-prereq-e2e"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "work-order-e2e"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "chat-expiry-e2e"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "sitemap"

[[workflows.workflow]]
name = "typecheck-rentnotice-pro"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter rentnotice-pro exec tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "mobile-layout-www"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:mobile-layout"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "merge-field-picker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:merge-field-picker"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "state-prereq-e2e"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:state-prereq"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "work-order-e2e"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:work-order"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "chat-expiry-e2e"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:chat-expiry"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "sitemap"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:sitemap"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0", "github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
EMAIL_FROM = "RentNotice Pro <noreply@rentnoticepro.com>"

[userenv.development]
ADMIN_PANEL_EMAIL = "admin@rentnoticepro.com"
ADMIN_PANEL_PASSWORD = "rnp-dev-admin-2026"

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 24772
externalPort = 3002

[[ports]]
localPort = 24773
externalPort = 4200

[[ports]]
localPort = 25069
externalPort = 3000

[[ports]]
localPort = 25116
externalPort = 3001
